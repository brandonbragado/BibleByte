# Supabase — Project URL + anon key (Settings → API).
# Apple / Google OAuth: no client secrets in this file—enable providers + redirect URLs in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — required for DELETE account flow (`deleteAccountAction`).
# Never expose to the browser or commit real keys.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for GET /api/cron/reminders (Vercel Cron or external scheduler)
CRON_SECRET=

# Optional rate limits (requests per minute per IP per route bucket — in-memory on single instances).
# TODO[SCALE]: Replace with Redis / Upstash when running many instances.
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_ANALYTICS_PER_MINUTE=120
RATE_LIMIT_SNIPPET_PER_MINUTE=180
RATE_LIMIT_PUSH_REGISTER_PER_MINUTE=10
RATE_LIMIT_ACCOUNT_DELETE_PER_MINUTE=3
RATE_LIMIT_PROFILE_IDENTITY_PER_MINUTE=30
RATE_LIMIT_SCRIPTURE_PER_MINUTE=90

# Scripture provider (mock | public_domain | licensed_niv | api_bible) — see src/lib/scripture/*
SCRIPTURE_PROVIDER_MODE=mock
# When api_bible: /api/scripture/bibles, books, passages, search call API.Bible; chapters always works per mode below.
# API.Bible — server-only; never expose API_BIBLE_KEY to the client. Use biblebyte /api/scripture/* from the browser.
API_BIBLE_KEY=
# Used only when NIV_SCRIPTURE_LICENSE_APPROVED=true; no non-NIV fallback is allowed.
API_BIBLE_NIV_BIBLE_ID=78a9f6124f344018-01
# Optional — defaults to https://api.scripture.api.bible/v1
# API_BIBLE_BASE_URL=
# Optional — tuning API.Bible HTTP client (server-only)
API_BIBLE_FETCH_TIMEOUT_MS=15000
API_BIBLE_MAX_RETRIES=2
# Home “Daily verse” card: when SCRIPTURE_PROVIDER_MODE=api_bible, live text is fetched by default (daily_verses.reference or fallback rotation). Set to false/0/off to keep placeholder body only.
# HOME_DAILY_VERSE_USE_SCRIPTURE_API=false
# Global legal gate for any licensed NIV text from upstream (default off)
NIV_SCRIPTURE_LICENSE_APPROVED=false
# Widget / push: separate flags so surfaces stay placeholder-only until explicitly enabled
SCRIPTURE_ALLOW_LICENSED_TEXT_WIDGETS=false
# When true, widget/snippet always uses SCRIPTURE_WIDGET_SAFE_BODY if widgets are not licensed (stricter than DB placeholders)
SCRIPTURE_WIDGET_STRICT_BODY=false
SCRIPTURE_ALLOW_LICENSED_TEXT_PUSH=false
# Caching & offline (default conservative — do not enable for NIV until counsel clears)
SCRIPTURE_ALLOW_FULL_CHAPTER_CACHE=false
SCRIPTURE_ALLOW_OFFLINE_BUNDLES=false
# TODO[NIV_LICENSE]: Server-only licensed API — never expose keys to the client
SCRIPTURE_LICENSED_UPSTREAM_URL=
SCRIPTURE_LICENSED_API_KEY=

# Site URL used for OAuth redirects on Vercel
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — required for POST /api/ai/chat assistant replies (503 ai_not_configured if unset)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# BibleByte Nest API — copy to `.env` and fill values (never commit `.env`).
#
# Bible Chat requires OPENAI_API_KEY. JWT validation requires Supabase vars below.

PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biblebites

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=

# Bible Chat — POST /v1/bible-chat (required for chat). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=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
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  supabaseAuthUserId String                 @unique
  provider           String                 @default("anonymous")
  isAnonymous        Boolean                @default(true)
  createdAt          DateTime               @default(now())
  lastSignInAt       DateTime               @default(now())
  deletedAt          DateTime?
  preferences        UserPreference?
  progress           Progress[]
  streak             Streak?
  schedules          NotificationSchedule[]
  analytics          AnalyticsEvent[]
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  goals           String[]
  topics          String[]
  reminderTime    String
  timezone        String
  dailyAmountType String
  analyticsOptIn  Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id])
}

model Lesson {
  id               String    @id @default(cuid())
  dateKey          String    @unique
  title            String
  estimatedMinutes Int
  nivContentStatus String
  segments         Segment[]
  progress         Progress[]
}

model Segment {
  id                       String @id @default(cuid())
  lessonId                 String
  verseReference           String
  scriptureTextPlaceholder String
  contextExplanation       String
  reflectionQuestion       String
  actionPrompt             String
  orderIndex               Int
  lesson                   Lesson @relation(fields: [lessonId], references: [id])
}

model Snippet {
  id                     String   @id @default(cuid())
  dateKey                String   @unique
  verseReference         String
  snippetTextPlaceholder String
  cachedUntil            DateTime
}

model Progress {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  status          String
  completedAt     DateTime?
  durationSeconds Int?
  user            User     @relation(fields: [userId], references: [id])
  lesson          Lesson   @relation(fields: [lessonId], references: [id])
}

model Streak {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentStreak     Int
  longestStreak     Int
  lastCompletedDate DateTime?
  user              User     @relation(fields: [userId], references: [id])
}

model NotificationSchedule {
  id         String   @id @default(cuid())
  userId     String
  localTime  String
  timezone   String
  enabled    Boolean
  lastSentAt DateTime?
  user       User     @relation(fields: [userId], references: [id])
}

model AnalyticsEvent {
  id           String   @id @default(cuid())
  userId       String?
  eventName    String
  metadataJson Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
}
